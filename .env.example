OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=

# Vision QC model (reads slide screenshots and flags layout failures).
OPENAI_VISION_QC_MODEL=gpt-4.1

# Run the deterministic cleanup passes (de-overlap, reflow, card/chart fixes).
ENABLE_VISUAL_QC_REPAIR=true

# LLM geometric fallback for slides still failing after deterministic fixes.
ENABLE_LLM_FIX_FALLBACK=true
OPENAI_LLM_FIX_MODEL=gpt-4.1
LLM_FIX_MAX_PASSES=1
